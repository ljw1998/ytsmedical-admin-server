NODE_ENV=development
PORT=5001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# SMTP (Email)
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SENDER_EMAIL=your_email@yourdomain.com
SENDER_PASSWORD=your_email_password

# Password Reset
PASSWORD_RESET_URL=https://admin.yourdomain.com/reset-password

# NinjaVan API
NINJAVAN_ENV=sandbox
NINJAVAN_BASE_URL=https://api-sandbox.ninjavan.co/sg
NINJAVAN_CLIENT_ID=your_client_id
NINJAVAN_CLIENT_SECRET=your_client_secret
NINJAVAN_DEFAULT_PICKUP_TIMESLOT_START=09:00
NINJAVAN_DEFAULT_PICKUP_TIMESLOT_END=18:00
NINJAVAN_TIMEZONE=Asia/Kuala_Lumpur

# Meta Marketing API
META_SYSTEM_USER_TOKEN=your_meta_system_user_token
META_API_VERSION=v25.0

# Cron Auth (for Cloud Scheduler)
CRON_AUTH_SECRET=your_cron_auth_secret

# Logging
LOG_LEVEL=info
